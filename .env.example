# =============================================================================
# Pryrox — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit your .env file to version control.
# See docs/environment-variables.md for full descriptions of each variable.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (Prisma — required)
# Vercel/serverless: use Supabase *transaction* pooler (port 6543) + pgbouncer=true
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# Migrations (Prisma CLI): use session pooler (port 5432) or direct connection
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
# URL-encode special characters in the password (e.g. $ → %24).
# Prisma sets connection_limit automatically based on VERCEL env var.
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.your-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres?sslmode=require

# -----------------------------------------------------------------------------
# Auth (required — no Supabase GoTrue)
# Apply SQL migrations: npm run db:sql:push (includes app_sessions)
# -----------------------------------------------------------------------------
NATIVE_AUTH_ENABLED=true
AUTH_SECRET=generate-a-random-string-at-least-32-characters-long

# Google OAuth (optional — Google Cloud Console → OAuth 2.0 Client)
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret


# -----------------------------------------------------------------------------
# Entitlements
# Set to false only for staged rollout; when true or unset, API and UI gates enforce plan features.
# -----------------------------------------------------------------------------
ENTITLEMENTS_ENFORCE=true

# Sidebar / in-page gates: hide locked items (default) or show with lock icon (lock)
NEXT_PUBLIC_NAV_ENTITLEMENT_MODE=hide

# -----------------------------------------------------------------------------
# Application
# Base URL of the running application. Used in KPay callback URLs and
# internal server-to-server fetch calls.
# -----------------------------------------------------------------------------

# Public base URL — REQUIRED on Vercel for Polar/KPay return URLs and auth emails.
# Local: http://localhost:3000
# Production: https://your-project.vercel.app (or your custom domain, no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal base URL (optional; should match NEXT_PUBLIC_APP_URL when set)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Nest API (browser calls migrated routes directly)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Required for /api/cron/* — external scheduler (e.g. cron-job.org) sends Authorization: Bearer <CRON_SECRET>
# Also accepts x-cron-secret header or ?secret= for manual triggers.
# ClickHouse safety-net sync: GET/POST https://<domain>/api/cron/clickhouse-sync
CRON_SECRET=your-random-cron-secret-here

# Rate limit backend: memory (default on Vercel), redis (REDIS_URL), or postgres (not recommended on serverless)
# RATE_LIMIT_STORE=memory

# Platform billing currency — catalog prices, invoices, admin KPIs. Default: RWF
NEXT_PUBLIC_PLATFORM_CURRENCY=RWF

# Polar card checkout currency (what the customer is charged on card). Default: usd
# Catalog plan prices remain in RWF; Pryrox stores RWF on payment_transactions.
POLAR_CHECKOUT_CURRENCY=usd
# When POLAR_CHECKOUT_CURRENCY=usd, used to set Polar product prices (RWF ÷ rate → USD cents)
POLAR_RWF_PER_USD=1300

# Auto-cancel pending payments/subscriptions after this many days (daily cron)
PENDING_PAYMENT_EXPIRE_DAYS=7


# -----------------------------------------------------------------------------
# Polar (card / international subscriptions)
# Paid plans auto-sync to Polar when created/updated in Admin → Subscriptions.
#
# On Vercel, set NEXT_PUBLIC_APP_URL to your deployment URL, then in Polar Dashboard:
#   Webhook:  https://<your-domain>/api/polar/webhook
# Checkout success redirects are built automatically, e.g.:
#   https://<your-domain>/payment/success?provider=polar&return=settings&checkout_id=...
# (Do not use localhost in production env vars.)
# -----------------------------------------------------------------------------

POLAR_ACCESS_TOKEN=polar_pat_...
POLAR_WEBHOOK_SECRET=whsec_...
# sandbox (default) or production
POLAR_SERVER=sandbox
# Checkout currency on Polar (usd recommended; RWF prices converted using rate below)
POLAR_CHECKOUT_CURRENCY=usd
# RWF per 1 USD for converting plan prices to Polar amounts (tune to your FX)
POLAR_RWF_PER_USD=1300
# Optional prefix for Polar product names (leave empty to use the plan name from admin as-is)
# POLAR_PRODUCT_NAME_PREFIX=Pryrox 


# -----------------------------------------------------------------------------
# File uploads (pharmacy logos, platform reports)
# Cloudinary (optional) — CDN-backed logos when configured.
# Otherwise logos and reports are stored on local disk (VPS-ready).
# UPLOAD_DIR defaults to ./uploads (served via /api/files/...).
# -----------------------------------------------------------------------------
# UPLOAD_DIR=/var/lib/pryrox/uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# -----------------------------------------------------------------------------
# SMTP fallback (Nodemailer)
# Used for staff invite emails, sign-up confirmation, and password reset.
# Sign-up confirmation and password reset links are sent via this SMTP server.
# -----------------------------------------------------------------------------

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="Pryrox <noreply@your-domain.com>"
# Set to "true" for port 465 (implicit TLS)
SMTP_SECURE=false

# -----------------------------------------------------------------------------
# Redis (optional — required for email job queue / maintenance notifications)
# Upstash (serverless): https://console.upstash.com
# Railway: https://railway.app
# Or self-hosted: redis://127.0.0.1:6379
# -----------------------------------------------------------------------------
# REDIS_URL=redis://default:your-password@your-redis-host:6379
# Or individual fields:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# -----------------------------------------------------------------------------
# NVIDIA AI (optional — enables AI-powered drug safety analysis)
# Uses NVIDIA NIM API with OpenAI-compatible SDK
# Get API key: https://build.nvidia.com/
# -----------------------------------------------------------------------------
# NVIDIA_API_KEY=nvapi-your-key-here
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# -----------------------------------------------------------------------------
# ClickHouse analytics (optional — dashboard / reports)
# Local: docker compose up -d clickhouse
# Then:  npm run clickhouse:migrate && npm run clickhouse:sync
# Play UI: http://localhost:8123/play
# When unset in production, app keeps using Postgres for analytics.
# -----------------------------------------------------------------------------
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=pryrox
CLICKHOUSE_PASSWORD=pryrox_dev
CLICKHOUSE_DATABASE=pryrox_analytics
# When CLICKHOUSE_URL is set, analytics GETs (dashboard/sales/reports charts)
# read from ClickHouse and fall back to Postgres on error.
